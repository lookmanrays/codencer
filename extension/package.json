{
  "name": "codencer-bridge",
  "displayName": "Codencer Bridge",
  "description": "Local alpha GUI for Codencer orchestration",
  "version": "0.2.0-alpha",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codencer.connect",
        "title": "Codencer: Connect to Daemon"
      },
      {
        "command": "codencer.startRun",
        "title": "Codencer: Start Run"
      },
      {
        "command": "codencer.approveGate",
        "title": "Codencer: Approve Gate",
        "icon": "$(check)"
      },
      {
        "command": "codencer.rejectGate",
        "title": "Codencer: Reject Gate",
        "icon": "$(x)"
      },
      {
        "command": "codencer.retryStep",
        "title": "Codencer: Retry Step",
        "icon": "$(refresh)"
      },
      {
        "command": "codencer.inspectResult",
        "title": "Codencer: Inspect Result",
        "icon": "$(json)"
      },
      {
        "command": "codencer.inspectValidations",
        "title": "Codencer: Inspect Validations",
        "icon": "$(shield)"
      },
      {
        "command": "codencer.openArtifact",
        "title": "Codencer: Open Artifact"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "codencer.approveGate",
          "when": "viewItem == gate",
          "group": "inline"
        },
        {
          "command": "codencer.rejectGate",
          "when": "viewItem == gate",
          "group": "inline"
        },
        {
          "command": "codencer.retryStep",
          "when": "viewItem == step",
          "group": "inline"
        },
        {
          "command": "codencer.inspectResult",
          "when": "viewItem == step || viewItem == result",
          "group": "1_inspection"
        },
        {
          "command": "codencer.inspectValidations",
          "when": "viewItem == step || viewItem == validations",
          "group": "1_inspection"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "16.x",
    "typescript": "^5.1.3"
  }
}
