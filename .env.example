# Codencer Local Environment Template
# Copy this to .env if using a loader, or export these variables in your shell.

# --- GLOBAL SETTINGS ---
# ALL_ADAPTERS_SIMULATION_MODE=1  # If set, all adapters run in simulation mode

# --- CODEX ADAPTER ---
# Real Mode: Points to your installed codex-agent binary
# CODEX_BINARY=/usr/local/bin/codex-agent

# Simulation Mode: Stubs execution but ledgering and lifecycle are real
# CODEX_SIMULATION_MODE=1

# --- DAEMON SETTINGS ---
# These must match your config/default.json if you want overrides (future phase)
# Current daemon env support is limited; use config/default.json for host/port.
