# --- Codencer Orchestration Bridge Configuration ---

# --- Execution Modes ---
# Set to 1 to stub all agent execution. Useful for verifying the orchestrator state machine.
ALL_ADAPTERS_SIMULATION_MODE=1

# --- Tactical Agents (Real Mode) ---
# Path to the Codex agent binary (requires npm install -g @lookman/codex-agent)
CODEX_BINARY=codex-agent
# Set to 1 to stub only the Codex agent
CODEX_SIMULATION_MODE=0

# Path to the Claude agent binary (requires npm install -g @anthropic-ai/claude-code)
CLAUDE_BINARY=claude-code
CLAUDE_SIMULATION_MODE=0

# Path to the Qwen/Aider agent binary (requires pip install aider-chat)
AIDER_BINARY=aider
QWEN_SIMULATION_MODE=0

# --- Server Settings ---
PORT=8085
LOG_LEVEL=info

# --- Storage Paths (Optional overrides) ---
# DB_PATH=.codencer/codencer.db
# ARTIFACT_ROOT=.codencer/artifacts
# WORKSPACE_ROOT=.codencer/workspace
