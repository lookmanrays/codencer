{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TaskSpec",
  "description": "Canonical execution request contract for the bridge.",
  "type": "object",
  "required": ["version", "goal"],
  "properties": {
    "version": { "type": "string", "example": "v1" },
    "project_id": { "type": "string" },
    "run_id": { "type": "string", "description": "Optional. Auto-filled from the submit target run when omitted." },
    "phase_id": { "type": "string", "description": "Optional. Auto-filled by the daemon if omitted." },
    "step_id": { "type": "string", "description": "Optional. Auto-filled by the daemon if omitted." },
    "title": { "type": "string" },
    "goal": { "type": "string", "description": "The primary prompt or instruction for the agent." },
    "context": {
      "type": "object",
      "properties": {
        "summary": { "type": "string" }
      }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "allowed_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "forbidden_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "validations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "command"],
        "properties": {
          "name": { "type": "string" },
          "command": { "type": "string" }
        }
      }
    },
    "acceptance": {
      "type": "array",
      "items": { "type": "string" }
    },
    "stop_conditions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "policy_bundle": { "type": "string" },
    "adapter_profile": { "type": "string", "description": "Preferred adapter (e.g., codex, claude)." },
    "timeout_seconds": { "type": "integer", "default": 300 },
    "is_simulation": { "type": "boolean", "default": false }
  }
}
