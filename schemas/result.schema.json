{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ResultSpec",
  "description": "Canonical execution result contract for the bridge.",
  "type": "object",
  "required": ["version", "run_id", "step_id", "state", "summary"],
  "properties": {
    "version": { "type": "string", "example": "v1" },
    "run_id": { "type": "string" },
    "phase_id": { "type": "string" },
    "step_id": { "type": "string" },
    "attempt_id": { "type": "string" },
    "adapter": { "type": "string" },
    "state": {
      "type": "string",
      "description": "Step lifecycle state: pending, running, completed, failed_terminal, timeout, cancelled, needs_manual_attention.",
      "enum": [
        "pending",
        "dispatching",
        "running",
        "collecting_artifacts",
        "validating",
        "completed",
        "completed_with_warnings",
        "needs_approval",
        "needs_manual_attention",
        "failed_retryable",
        "failed_terminal",
        "timeout",
        "cancelled"
      ]
    },
    "summary": { "type": "string" },
    "files_changed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "validations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "state": { 
            "type": "string",
            "description": "Validation outcome state: not_run, running, passed, failed, errored."
          },
          "passed": { "type": "boolean" }
        }
      }
    },
    "needs_human_decision": { "type": "boolean" },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "raw_output": { "type": "string" },
    "raw_output_ref": { "type": "string" },
    "is_simulation": { 
      "type": "boolean",
      "description": "True if result is from a stub/dev mode. NOT for performance benchmarking."
    },
    "retryable": { "type": "boolean" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
